# Required — who to watch and who to notify
PR_SHEPHERD_AUTHOR_USERNAME=                   # GitHub username whose PRs to monitor
PR_SHEPHERD_NOTIFY_AGENT=                      # Agent codename to send all PR issues to

# Conductor MCP server URL (omit to log messages to stdout instead)
PR_SHEPHERD_CONDUCTOR_URL=

# Where runtime state files live (default: ./data)
PR_SHEPHERD_DATA_DIR=./data

# Chat notifications — Slack/Discord/Teams incoming webhook URL (optional)
PR_SHEPHERD_WEBHOOK_URL=

# Polling tuning (all optional)
PR_SHEPHERD_POLL_INTERVAL=180
PR_SHEPHERD_STALE_HOURS=4
PR_SHEPHERD_REQUIRED_APPROVALS=1
PR_SHEPHERD_DRY_RUN=false
PR_SHEPHERD_DEFAULT_REPO=

# Review inbox — auto-detect incoming review assignments (optional)
PR_SHEPHERD_REVIEW_INBOX_ENABLED=false
PR_SHEPHERD_REVIEW_INBOX_USER=                 # GitHub username to watch for review requests
PR_SHEPHERD_REVIEW_INBOX_AGENT=                # Agent to notify (falls back to PR_SHEPHERD_NOTIFY_AGENT)
